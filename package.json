{
  "name": "course-selling-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "seed:admin": "npm run seed:admin --workspace server",
    "seed:courses": "npm run seed:courses --workspace server",
    "seed": "npm run seed:admin && npm run seed:courses"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
